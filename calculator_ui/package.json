    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
